# ============================================================
# Loomis — Environment Variables (example)
# Copy to .env.local and fill in. NEVER commit real secrets.
# ============================================================

# --- Runtime ---
NODE_ENV=development
API_PORT=18080

# --- Database (local Docker) ---
DATABASE_URL=postgresql://loomis:loomis@localhost:15432/loomis
DATABASE_AUDIT_URL=postgresql://loomis:loomis@localhost:15432/loomis_audit

# --- Redis (local Docker) ---
REDIS_URL=redis://localhost:16379

# --- Auth ---
# In prod these come from AWS Secrets Manager, not env.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL_SECONDS=28800
JWT_REFRESH_TTL_SECONDS=2592000
REFRESH_TOKEN_HMAC_SECRET=
REFERRAL_CODE_HMAC_SECRET=
TOTP_ENCRYPTION_KEY=
TOTP_ISSUER=Loomis

# --- Web (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:18080/api/v1
WEB_APP_BASE_URL=http://localhost:3000

# --- Production (loomis.digital) — set on Vercel + API host ---
# Vercel (apps/web):
#   LOOMIS_API_BASE_URL=https://api.loomis.digital/api/v1
#   NEXT_PUBLIC_API_BASE_URL=https://api.loomis.digital/api/v1
#   WEB_APP_BASE_URL=https://www.loomis.digital
# API host (Railway/Render):
#   WEB_APP_BASE_URL=https://www.loomis.digital
#   PAYMENT_REDIRECT_BASE_URL=https://www.loomis.digital/payments/complete
#   PAYSTACK webhook URL: https://api.loomis.digital/api/v1/webhooks/paystack
# Optional: mirror API VAPID public key for offline-first SW registration (also served via GET /comms/push/config)
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=

# --- Mobile (Expo) — same API port as web ---
EXPO_PUBLIC_API_BASE_URL=http://localhost:18080/api/v1

# --- Paystack (sandbox keys from dashboard → Settings → API Keys & Webhooks) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Optional; defaults to PAYSTACK_SECRET_KEY (Paystack signs webhooks with your secret key)
PAYSTACK_WEBHOOK_SECRET=
PAYMENT_REDIRECT_BASE_URL=http://localhost:3000/payments/complete
# iOS/Android return after Paystack checkout (must match app scheme + route)
PAYMENT_REDIRECT_MOBILE_URL=loomis://payments/complete
# Optional mirror for Expo/web clients (falls back to PAYSTACK_PUBLIC_KEY in mobile app.config.ts)
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
# Webhooks: Paystack rejects localhost — use ngrok (see README) and set Test Webhook URL to:
# https://<your-ngrok-host>/api/v1/webhooks/paystack

# --- Email / SMS / Push (SRS §10.3 / §10.4) ---
# Resend: API key from https://resend.com/api-keys; FROM must use a verified domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TERMII_API_KEY=
TERMII_SENDER_ID=
# FCM: paste the full Firebase service account JSON on one line, or use a file mount in prod
FCM_SERVICE_ACCOUNT_JSON=
# APNs token-based auth (Apple Developer portal)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=

# Web Push VAPID (PWA parent absence alerts — generate with `npx web-push generate-vapid-keys`)
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:support@loomis.app

# --- Storage ---
S3_BUCKET=loomis-dev-551656632198-eu-north-1-an
S3_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
