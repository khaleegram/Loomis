{
  "name": "@loomis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "node --env-file=../../.env.local ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "start:compiled": "node dist/src/index.js",
    "db:migrate:prod": "node ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:railway": "node scripts/migrate-railway-prod.mjs",
    "db:verify:railway": "node scripts/verify-migrations.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=../../.env.local ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "node --env-file=../../.env.local ./node_modules/tsx/dist/cli.mjs scripts/seed-dev.ts",
    "db:seed:rich": "node --env-file=../../.env.local ./node_modules/tsx/dist/cli.mjs scripts/seed-rich-school.ts",
    "db:seed:rich:prod": "node --env-file=../../.env.railway.local ./node_modules/tsx/dist/cli.mjs scripts/seed-rich-school.ts",
    "db:seed:timetables": "node --env-file=../../.env.local ./node_modules/tsx/dist/cli.mjs scripts/seed-rich-school.ts --timetables-only",
    "db:seed:advanced-demo": "node --env-file=../../.env.local ./node_modules/tsx/dist/cli.mjs scripts/seed-advanced-demo-data.ts",
    "db:seed:prod": "node ./node_modules/tsx/dist/cli.mjs scripts/seed-prod-all.ts",
    "db:hackathon:reset-jss3b:prod": "node --env-file=../../.env.railway.local ./node_modules/tsx/dist/cli.mjs scripts/hackathon-reset-jss3b-fees.ts",
    "db:hackathon:reset-jss3b:railway": "node scripts/hackathon-reset-railway-prod.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "resend": "^4.8.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@loomis/contracts": "workspace:*",
    "@loomis/core": "workspace:*",
    "apns2": "^12.2.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.78.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^5.0.0",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "pino": "^9.4.0",
    "postgres": "^3.4.4",
    "speakeasy": "^2.0.0",
    "tsx": "^4.19.1",
    "uuidv7": "^1.0.2",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@loomis/config": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/speakeasy": "^2.0.10",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.24.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
