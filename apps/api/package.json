{
  "name": "@loomis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "node --env-file=../../.env.local ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@loomis/contracts": "workspace:*",
    "@loomis/core": "workspace:*",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.33.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "postgres": "^3.4.4",
    "uuidv7": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@loomis/config": "workspace:*",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
